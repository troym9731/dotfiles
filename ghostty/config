cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true
font-family = Hasklug Nerd Font Mono
font-size = 14.0
font-feature = -calt
font-feature = -liga
font-feature = -dlig
font-thicken = true
font-codepoint-map = U+21D0-U+21FF,U+E000-U+E00A,U+E0A0-U+E0A3,U+E0B0-U+E0C8,U+E0CA,U+E0CC-U+E0D7,U+E200-U+E2A9,U+E300-U+E3E3,U+E5FA-U+E6B7,U+E700-U+E8EF,U+EA60-U+EC1E,U+ED00-U+F2FF,U+EE00-U+EE0B,U+F300-U+F381,U+F400-U+F533,U+F0001-U+F1AF0=Symbols Nerd Font
macos-titlebar-style = tabs
scrollback-limit = 4294967295
shell-integration-features = no-cursor
split-divider-color = #505075
theme = catppuccin-mocha.conf
unfocused-split-opacity = 1
window-height = 1000000
window-width = 1000000

# Search entire scrollback history in default text editor
keybind = ctrl+space>shift+l=goto_window:previous
keybind = ctrl+space>shift+k=goto_window:next
keybind = ctrl+space>\=new_split:right
keybind = ctrl+space>-=new_split:down
keybind = ctrl+space>l=previous_tab
keybind = ctrl+space>k=next_tab
keybind = cmd+ctrl+k=goto_split:top
keybind = cmd+ctrl+l=goto_split:right
keybind = cmd+ctrl+j=goto_split:bottom
keybind = cmd+ctrl+h=goto_split:left
keybind = cmd+ctrl+i=toggle_split_zoom
keybind = cmd+ctrl+u=scroll_page_up
keybind = cmd+ctrl+n=scroll_page_down
keybind = cmd+ctrl+y=scroll_page_lines:-1
keybind = cmd+ctrl+e=scroll_page_lines:1
keybind = cmd+ctrl+b=scroll_to_bottom
keybind = cmd+ctrl+t=jump_to_prompt:-1
keybind = cmd+ctrl+r=jump_to_prompt:1
keybind = cmd+k=unbind
